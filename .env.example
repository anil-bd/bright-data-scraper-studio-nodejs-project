# Bright Data Scraper Studio - environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# API token from Bright Data: https://brightdata.com/cp/setting
BRIGHT_DATA_API_TOKEN=your_api_token_here

# Collector ID from Scraper Studio (starts with c_)
BRIGHT_DATA_COLLECTOR_ID=c_xxxxxxxxxxxxxxxx
